{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "lib": ["ES2020", "DOM"],
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@shared/*": ["./src/shared/*"],
      "@hook/*": ["./src/hook/*"],
      "@panel/*": ["./src/panel/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "vite.config.*.ts"]
}
